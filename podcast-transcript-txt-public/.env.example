# Volcano Engine ASR Configuration (Optional)
# Get credentials from: https://console.volcengine.com/
# Navigate to: 语音技术 (Speech Technology) → 应用管理

# Application ID (APP ID)
VOLCANO_APP_ID=your_app_id_here

# Access Token (Access Key)
VOLCANO_ACCESS_KEY=your_access_key_here

# Optional: Secret Key (for advanced API features)
# VOLCANO_SECRET_KEY=your_secret_key_here

# Local ASR Model (fallback if Volcano Engine is unavailable)
PODCAST_ASR_MODEL=small

# Local ASR Model Root Directory
# PODCAST_ASR_MODEL_ROOT=/path/to/.codex/models/faster-whisper

# yt-dlp Path (for YouTube subtitle/audio extraction)
# YT_DLP_PATH=/usr/local/bin/yt-dlp
